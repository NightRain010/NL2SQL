# 不打包进镜像，减少上下文体积和流量
.git
.gitignore
.env
.env.*
!.env.example
*.md
.cursor
__pycache__
*.py[cod]
*.pyo
.pytest_cache
.coverage
htmlcov
*.egg-info
.eggs

# 后端
backend/.venv
backend/**/__pycache__
backend/tests

# 前端
frontend/node_modules
frontend/dist
frontend/**/__tests__
frontend/**/*.test.ts
frontend/**/*.spec.ts

# IDE 与系统
.idea
.vscode
*.log
.DS_Store
Thumbs.db
