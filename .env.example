# 生产部署：复制为 .env 并在服务器上填写真实值，不要提交 .env
# 镜像内不包含密钥，全部由运行时注入

# DeepSeek AI 配置
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MySQL（同 compose 部署时填 mysql，端口 3306；宿主机或其它机器填对应 IP 与端口）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=8306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=nl2sql_platform

# JWT（生产环境务必改为随机强密钥）
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
